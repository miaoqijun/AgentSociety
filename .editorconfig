# EditorConfig is awesome: https://EditorConfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Python
[*.py]
indent_size = 4

# Frontend / VS Code extension
[*.{ts,tsx,js,jsx,json,yaml,yml,css,html}]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Makefile (requires tabs)
[Makefile]
indent_style = tab

# Markdown
[*.md]
trim_trailing_whitespace = false

# reStructuredText
[*.rst]
indent_size = 3

# TOML (pyproject.toml, etc.)
[*.toml]
indent_size = 2

# YAML
[*.{yaml,yml}]
indent_size = 2
