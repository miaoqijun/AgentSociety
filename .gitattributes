# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.py text eol=lf diff=python
*.pyx text eol=lf diff=python
*.pxd text eol=lf diff=python

# Web / Frontend
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.vue text eol=lf

# Config / Data
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.csv text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.po text eol=lf
*.pot text eol=lf
*.mo binary

# Shell scripts
*.sh text eol=lf

# Windows scripts (intentionally CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.mp3 binary

# Generated / vendored — exclude from language stats
frontend/node_modules/** linguist-vendored
frontend/package-lock.json linguist-generated
extension/node_modules/** linguist-vendored
extension/package-lock.json linguist-generated
packages/agentsociety2/docs/_build/** linguist-generated
.ruff_cache/** linguist-generated
