{
  "name": "ai-social-scientist",
  "displayName": "AI Social Scientist",
  "description": "AI Social Scientist - Next-generation human-AI interaction interface for social science research",
  "version": "0.0.1",
  "publisher": "tsinghua-fib-lab",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsinghua-fib-lab/agentsociety.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "resources/icon128.png",
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "aiSocialScientist": [
        {
          "id": "projectStructureView",
          "name": "Project Structure",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiSocialScientist",
          "title": "AI Social Scientist",
          "icon": "resources/activitybar.png"
        }
      ]
    },
    "commands": [
      {
        "command": "aiSocialScientist.initProject",
        "title": "AI Social Scientist: Initialize Research Project",
        "icon": "$(add)"
      },
      {
        "command": "aiSocialScientist.openChat",
        "title": "AI Social Scientist: Open AI Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "aiSocialScientist.deleteLiterature",
        "title": "AI Social Scientist: Delete Literature",
        "icon": "$(trash)"
      },
      {
        "command": "aiSocialScientist.renameLiterature",
        "title": "AI Social Scientist: Rename Literature",
        "icon": "$(edit)"
      },
      {
        "command": "aiSocialScientist.parseWithMinerU",
        "title": "AI Social Scientist: Parse with MinerU",
        "icon": "$(file-code)"
      },
      {
        "command": "aiSocialScientist.openMarkdownInEditor",
        "title": "AI Social Scientist: Open Markdown in Editor",
        "icon": "$(edit)"
      },
      {
        "command": "agentsociety.viewPrefillParams",
        "title": "AI Social Scientist: View Prefill Parameters",
        "icon": "$(settings)"
      },
      {
        "command": "aiSocialScientist.openReplay",
        "title": "AI Social Scientist: Open Simulation Replay",
        "icon": "$(play-circle)"
      },
      {
        "command": "aiSocialScientist.startBackend",
        "title": "AI Social Scientist: Start Backend Service",
        "icon": "$(play)"
      },
      {
        "command": "aiSocialScientist.stopBackend",
        "title": "AI Social Scientist: Stop Backend Service",
        "icon": "$(stop)"
      },
      {
        "command": "aiSocialScientist.restartBackend",
        "title": "AI Social Scientist: Restart Backend Service",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSocialScientist.showBackendLogs",
        "title": "AI Social Scientist: Show Backend Logs",
        "icon": "$(output)"
      },
      {
        "command": "aiSocialScientist.showBackendStatus",
        "title": "AI Social Scientist: Show Backend Status",
        "icon": "$(info)"
      },
      {
        "command": "aiSocialScientist.openConfigPage",
        "title": "AI Social Scientist: Open Configuration",
        "icon": "$(settings)"
      },
      {
        "command": "aiSocialScientist.toggleParseMode",
        "title": "AI Social Scientist: Toggle PDF Parse Mode",
        "icon": "$(check-square)"
      },
      {
        "command": "aiSocialScientist.scanCustomModules",
        "title": "AI Social Scientist: Scan Custom Modules",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSocialScientist.testCustomModules",
        "title": "AI Social Scientist: Test Custom Modules",
        "icon": "$(play)"
      },
      {
        "command": "aiSocialScientist.cleanCustomModules",
        "title": "AI Social Scientist: Clean Custom Modules",
        "icon": "$(trash)"
      },
      {
        "command": "aiSocialScientist.listCustomModules",
        "title": "AI Social Scientist: List Custom Modules",
        "icon": "$(list-tree)"
      },
      {
        "command": "aiSocialScientist.scanAgentSkills",
        "title": "AI Social Scientist: Scan Agent Skills",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSocialScientist.importAgentSkill",
        "title": "AI Social Scientist: Import Agent Skill",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSocialScientist.toggleAgentSkill",
        "title": "AI Social Scientist: Toggle Agent Skill",
        "icon": "$(check)"
      },
      {
        "command": "aiSocialScientist.reloadAgentSkill",
        "title": "AI Social Scientist: Reload Agent Skill",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSocialScientist.openSkillFolder",
        "title": "AI Social Scientist: Open Skill Folder in File Manager",
        "icon": "$(folder)"
      },
      {
        "command": "aiSocialScientist.formatJsonFile",
        "title": "AI Social Scientist: Format and View JSON",
        "icon": "$(json)"
      },
      {
        "command": "aiSocialScientist.viewLiteratureIndex",
        "title": "AI Social Scientist: View Literature Index",
        "icon": "$(book)"
      },
      {
        "command": "aiSocialScientist.viewStepsYaml",
        "title": "AI Social Scientist: View Steps Timeline",
        "icon": "$(list-ordered)"
      },
      {
        "command": "aiSocialScientist.viewExperimentResults",
        "title": "AI Social Scientist: View Experiment Results",
        "icon": "$(graph)"
      },
      {
        "command": "aiSocialScientist.removeAgentSkill",
        "title": "AI Social Scientist: Remove Custom Skill",
        "icon": "$(trash)"
      },
      {
        "command": "aiSocialScientist.mineruStatusMenu",
        "title": "AI Social Scientist: MinerU Environment Status",
        "icon": "$(file-code)"
      },
      {
        "command": "aiSocialScientist.mineruRecheck",
        "title": "AI Social Scientist: Re-check MinerU Environment",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSocialScientist.mineruDownloadModels",
        "title": "AI Social Scientist: Download MinerU Models",
        "icon": "$(cloud-download)"
      },
      {
        "command": "aiSocialScientist.showMinerULogs",
        "title": "AI Social Scientist: Show MinerU Logs",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [],
      "view/item/context": [
        {
          "command": "aiSocialScientist.openReplay",
          "when": "view == projectStructureView && viewItem == experiment",
          "group": "1_actions"
        },
        {
          "command": "aiSocialScientist.deleteLiterature",
          "when": "view == projectStructureView && (viewItem == paper || viewItem == file || viewItem =~ /markdown/)",
          "group": "1_modification"
        },
        {
          "command": "aiSocialScientist.renameLiterature",
          "when": "view == projectStructureView && (viewItem == paper || viewItem == file || viewItem =~ /markdown/)",
          "group": "1_modification"
        },
        {
          "command": "aiSocialScientist.parseWithMinerU",
          "when": "view == projectStructureView && viewItem == paper",
          "group": "2_actions"
        },
        {
          "command": "aiSocialScientist.openMarkdownInEditor",
          "when": "view == projectStructureView && viewItem =~ /markdown/",
          "group": "2_actions"
        },
        {
          "command": "aiSocialScientist.toggleAgentSkill",
          "when": "view == projectStructureView && viewItem =~ /agentSkillItem.*enabled/",
          "group": "1_actions@1"
        },
        {
          "command": "aiSocialScientist.toggleAgentSkill",
          "when": "view == projectStructureView && viewItem =~ /agentSkillItem.*disabled/",
          "group": "1_actions@1"
        },
        {
          "command": "aiSocialScientist.removeAgentSkill",
          "when": "view == projectStructureView && viewItem =~ /agentSkillItem.*custom/",
          "group": "1_actions@2"
        },
        {
          "command": "aiSocialScientist.reloadAgentSkill",
          "when": "view == projectStructureView && viewItem =~ /agentSkillItem/",
          "group": "1_actions@2"
        },
        {
          "command": "aiSocialScientist.openSkillFolder",
          "when": "view == projectStructureView && viewItem =~ /agentSkillItem/",
          "group": "2_actions"
        },
        {
          "command": "aiSocialScientist.openSkillFolder",
          "when": "view == projectStructureView && viewItem == extensionSkillItem",
          "group": "2_actions"
        },
        {
          "command": "aiSocialScientist.formatJsonFile",
          "when": "view == projectStructureView && viewItem =~ /json/",
          "group": "2_actions"
        },
        {
          "command": "aiSocialScientist.viewLiteratureIndex",
          "when": "view == projectStructureView && viewItem =~ /literatureIndex/",
          "group": "1_actions"
        },
        {
          "command": "aiSocialScientist.viewStepsYaml",
          "when": "view == projectStructureView && viewItem =~ /stepsYaml/",
          "group": "1_actions"
        },
        {
          "command": "aiSocialScientist.viewExperimentResults",
          "when": "view == projectStructureView && viewItem =~ /experimentResults/",
          "group": "1_actions"
        }
      ]
    },
    "webview": [
      {
        "viewType": "aiSocialScientistChat",
        "title": "AI Chat",
        "icon": "$(comment-discussion)"
      }
    ],
    "customEditors": [
      {
        "viewType": "aiSocialScientist.simSettings",
        "displayName": "SIM Settings Editor",
        "selector": [
          {
            "filenamePattern": "**/SIM_SETTINGS.json"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "aiSocialScientist.initConfig",
        "displayName": "Init Config Editor",
        "selector": [
          {
            "filenamePattern": "**/init/init_config.json"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "AI Social Scientist",
      "properties": {
        "aiSocialScientist.backend.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "是否在插件启动时自动启动后端服务",
          "markdownDescription": "如果启用，插件启动时会自动启动后端服务。如果禁用，需要手动启动后端服务。"
        },
        "aiSocialScientist.chat.viewColumn": {
          "type": "string",
          "default": "beside",
          "enum": [
            "beside",
            "one",
            "two",
            "three",
            "four",
            "five",
            "six",
            "seven",
            "eight",
            "nine"
          ],
          "enumDescriptions": [
            "在当前编辑器旁边打开（默认）",
            "在第一列打开",
            "在第二列打开",
            "在第三列打开",
            "在第四列打开",
            "在第五列打开",
            "在第六列打开",
            "在第七列打开",
            "在第八列打开",
            "在第九列打开"
          ],
          "description": "Chat面板打开的视图列位置",
          "markdownDescription": "指定 Chat 面板打开时使用的视图列位置。选择固定的列（如 `two`、`three`）可以避免在打开其他页面（如 Replay）时 Chat 页面被替换或消失。默认为 `beside`（在当前编辑器旁边）。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build-webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-webview": "webpack --mode production",
    "watch-webview": "webpack --mode development --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "css-loader": "^6.8.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.4.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.2",
    "webpack": "^5.104.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.0",
    "@ant-design/x": "^2.0.0",
    "@ant-design/x-markdown": "^2.1.1",
    "@deck.gl/core": "^9.0.38",
    "@deck.gl/layers": "^9.0.38",
    "@deck.gl/react": "^9.0.38",
    "@deck.gl/widgets": "^9.2.11",
    "ajv": "^8.18.0",
    "antd": "^6.0.0",
    "dayjs": "^1.11.19",
    "i18next": "^23.7.0",
    "js-yaml": "^4.1.0",
    "mapbox-gl": "^3.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "react-map-gl": "~7.1.7"
  },
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6",
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "minimist": ">=1.0.0",
    "minimatch": ">=9.0.7",
    "diff": ">=3.5.1"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3",
      "minimist": ">=1.0.0",
      "minimatch": ">=9.0.7",
      "diff": ">=3.5.1"
    }
  }
}
