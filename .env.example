# Default LLM settings (required)
AGENTSOCIETY_LLM_API_KEY=your_api_key
AGENTSOCIETY_LLM_API_BASE=https://cloud.infini-ai.com/maas/v1
AGENTSOCIETY_LLM_MODEL=qwen3-next-80b-a3b-instruct

# Coder LLM settings (for code generation, optional)
AGENTSOCIETY_CODER_LLM_API_KEY=your_coder_api_key  # Falls back to AGENTSOCIETY_LLM_API_KEY if not set
AGENTSOCIETY_CODER_LLM_API_BASE=https://cloud.infini-ai.com/maas/v1  # Falls back to AGENTSOCIETY_LLM_API_BASE if not set
AGENTSOCIETY_CODER_LLM_MODEL=glm-5

# Nano LLM settings (for high-frequency operations, optional)
AGENTSOCIETY_NANO_LLM_API_KEY=your_nano_api_key  # Falls back to AGENTSOCIETY_LLM_API_KEY if not set
AGENTSOCIETY_NANO_LLM_API_BASE=https://cloud.infini-ai.com/maas/v1  # Falls back to AGENTSOCIETY_LLM_API_BASE if not set
AGENTSOCIETY_NANO_LLM_MODEL=qwen3-next-80b-a3b-instruct

# Analysis LLM settings (for data analysis, insight generation, and report writing, optional)
# Use a capable model for complex reasoning tasks
AGENTSOCIETY_ANALYSIS_LLM_API_KEY=your_analysis_api_key  # Falls back to AGENTSOCIETY_LLM_API_KEY if not set
AGENTSOCIETY_ANALYSIS_LLM_API_BASE=https://cloud.infini-ai.com/maas/v1  # Falls back to AGENTSOCIETY_LLM_API_BASE if not set
AGENTSOCIETY_ANALYSIS_LLM_MODEL=glm-5

# Embedding model settings (optional)
AGENTSOCIETY_EMBEDDING_API_KEY=your_embedding_api_key  # Falls back to AGENTSOCIETY_LLM_API_KEY if not set
AGENTSOCIETY_EMBEDDING_API_BASE=https://cloud.infini-ai.com/maas/v1  # Falls back to AGENTSOCIETY_LLM_API_BASE if not set
AGENTSOCIETY_EMBEDDING_MODEL=bge-m3

# Backend service settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# Workspace path for custom modules
# Set this to your workspace root directory (where custom/ folder is located)
WORKSPACE_PATH=/path/to/workspace

# Literature search API (统一学术文献检索服务)
LITERATURE_SEARCH_API_URL=http://localhost:8008/api/search
LITERATURE_SEARCH_API_KEY=lit-your-api-key-here

# Web search API (optional)
# 用于 miro_web_research 工具，需同时配置 URL 与 Token
WEB_SEARCH_API_URL=http://localhost:8003/mcp
WEB_SEARCH_API_TOKEN=your_web_search_api_bearer_token

# EasyPaper API (for generate paper tool; deploy from https://github.com/tsinghua-fib-lab/EasyPaper)
EASYPAPER_API_URL=http://localhost:8004
