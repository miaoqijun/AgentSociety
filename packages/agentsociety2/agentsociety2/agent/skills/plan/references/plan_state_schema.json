{
  "type": "object",
  "required": [
    "goal",
    "steps",
    "current_step",
    "started_tick",
    "status",
    "decision_mode",
    "failure_count"
  ],
  "properties": {
    "goal": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 6
    },
    "current_step": {
      "type": "integer",
      "minimum": 0
    },
    "started_tick": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "completed",
        "failed",
        "interrupted"
      ]
    },
    "decision_mode": {
      "type": "string",
      "enum": [
        "system2"
      ]
    },
    "failure_count": {
      "type": "integer",
      "minimum": 0
    },
    "last_error": {
      "type": [
        "string",
        "null"
      ]
    },
    "interrupt_reason": {
      "type": "string"
    },
    "resumable": {
      "type": "boolean"
    },
    "resume_conditions": {
      "type": "string"
    }
  }
}
