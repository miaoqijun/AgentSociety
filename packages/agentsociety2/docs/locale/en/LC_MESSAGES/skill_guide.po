msgid "在工作区文件中搜索"
msgstr "Search workspace files"

#: ../../skill_guide.md
msgid "`grep(\"pattern\", \".\")`"
msgstr "`grep(\"pattern\", \".\")`"

#: ../../skill_guide.md
