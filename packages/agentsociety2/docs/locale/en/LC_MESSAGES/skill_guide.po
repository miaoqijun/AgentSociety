msgid "进阶主题"
msgstr "Advanced topics"

#: ../../skill_guide.md:368
msgid "状态管理"
msgstr "State management"

#: ../../skill_guide.md:370
msgid "如果Skill需要维护状态，写入JSON文件："
msgstr "If the Skill needs to maintain state, write to the JSON file:"

