msgstr ""

#: ../../skill_guide.md
msgid "结束当前仿真步"
msgstr "End the current simulation step"

#: ../../skill_guide.md
msgid "带可选 summary"
msgstr "With an optional summary"

#: ../../skill_guide.md:118
msgid "没有 `bash` / `glob` / `codegen` / `batch` 工具；环境交互统一走 `ask_env`。"
msgstr ""
"There are no `bash` / `glob` / `codegen` / `batch` tools; environment "
