msgid "``kind=\"statistics\"``"
msgstr "``kind=\"statistics\"``"

#: ../../custom_modules.rst:170
msgid "统计工具（无参数，readonly=True）"
msgstr "Statistics tool (no parameters, readonly=True)"

#: ../../custom_modules.rst:171
msgid "``kind=None``"
msgstr "``kind=None``"

#: ../../custom_modules.rst:172
msgid "常规工具（任何参数，可以是 readonly=False）"
msgstr "Regular tool (any parameters, can be readonly=False)"

