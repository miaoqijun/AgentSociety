msgid "``kind=\"observe\"``"
msgstr "``kind=\"observe\"``"

#: ../../custom_modules.rst:168
msgid "观察工具（单个 agent_id 参数，readonly=True）"
msgstr "Observation tool (single agent_id parameter, readonly=True)"

