msgstr ""
"``type``: SQLite column type string. See ``ColumnType`` for available "
"values."

#: agentsociety2.storage.table_schema.ColumnDef:7 of
msgid "``nullable``：是否允许 NULL。"
msgstr "``nullable``: Whether NULL is allowed."

#: agentsociety2.storage.table_schema.ColumnDef:8 of
