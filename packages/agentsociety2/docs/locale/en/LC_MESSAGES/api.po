msgstr ""
"``tool_decision_max_retries``: max_retries passed to "
"``acompletion_with_pydantic_validation`` (default 10)"

#: agentsociety2.agent.person.PersonAgent.__init__:19 of
msgid "``model`` / ``llm_model``：LiteLLM 路由模型名（用于 token_counter 与 tiktoken 回退）"
msgstr ""
