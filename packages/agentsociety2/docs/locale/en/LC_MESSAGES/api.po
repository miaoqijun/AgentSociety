#: agentsociety2.config.config.Config:1 of
msgid "AgentSociety2 配置（环境变量来源）。"
msgstr "AgentSociety2 configuration (environment variable source)."

#: agentsociety2.config.config.Config:3 of
msgid "该类以“类属性”的形式暴露配置项，便于在不实例化的情况下读取。"
msgstr ""
"This class exposes configuration items in the form of \"class attributes\" "
"for easy reading without instantiation."

#: agentsociety2.config.config.Config:5 of
msgid "主要环境变量（节选）："
msgstr "Main environment variables (excerpt):"

#: agentsociety2.config.config.Config:7 of
msgid "``AGENTSOCIETY_HOME_DIR``：数据目录"
msgstr "``AGENTSOCIETY_HOME_DIR``: Data directory"

#: agentsociety2.config.config.Config:8 of
msgid ""
"``AGENTSOCIETY_LLM_API_KEY`` / ``AGENTSOCIETY_LLM_API_BASE`` / "
"``AGENTSOCIETY_LLM_MODEL``：默认模型配置"
msgstr ""
"``AGENTSOCIETY_LLM_API_KEY`` / ``AGENTSOCIETY_LLM_API_BASE`` / "
"``AGENTSOCIETY_LLM_MODEL``: Default model configuration"

#: agentsociety2.config.config.Config:9 of
msgid "``AGENTSOCIETY_CODER_LLM_*``：代码生成模型配置"
msgstr "``AGENTSOCIETY_CODER_LLM_*``: Code generation model configuration"

#: agentsociety2.config.config.Config:10 of
msgid "``AGENTSOCIETY_NANO_LLM_*``：高频/低延迟模型配置"
msgstr ""
"``AGENTSOCIETY_NANO_LLM_*``: High frequency/low latency model configuration"

#: agentsociety2.config.config.Config:11 of
msgid "``AGENTSOCIETY_ANALYSIS_LLM_*``：分析写作模型配置"
msgstr "``AGENTSOCIETY_ANALYSIS_LLM_*``: Analyze writing model configuration"

#: agentsociety2.config.config.Config:12 of
msgid "``AGENTSOCIETY_EMBEDDING_*``：embedding 配置"
msgstr "``AGENTSOCIETY_EMBEDDING_*``：embedding configuration"

#: agentsociety2.config.Config.HOME_DIR:1 of
msgid ""
"Base directory path for storing agent data, memories, and persistent files."
msgstr ""
"Base directory path for storing agent data, memories, and persistent files."

#: agentsociety2.config.Config.HOME_DIR:3 of
msgid ""
"Environment variable: AGENTSOCIETY_HOME_DIR Default: \"./agentsociety_data\""
msgstr ""
"Environment variable: AGENTSOCIETY_HOME_DIR Default: \"./agentsociety_data\""

#: agentsociety2.config.Config.HOME_DIR:6 of
msgid ""
"This directory will contain subdirectories for memories, agent states, and "
"other persistent data. The path can be absolute or relative to the current "
"working directory."
msgstr ""
"This directory will contain subdirectories for memories, agent states, and "
"other persistent data. The path can be absolute or relative to the current "
"working directory."

#: agentsociety2.config.Config.LLM_API_KEY:1 of
msgid "API key for authenticating with the default LLM service."
msgstr "API key for authenticating with the default LLM service."

#: agentsociety2.config.Config.LLM_API_KEY:3 of
msgid ""
"Environment variable: AGENTSOCIETY_LLM_API_KEY Default: None (must be set "
"for the system to function)"
msgstr ""
"Environment variable: AGENTSOCIETY_LLM_API_KEY Default: None (must be set "
"for the system to function)"

#: agentsociety2.config.Config.LLM_API_KEY:6 of
msgid ""
"This is the primary API key used for most LLM operations. If not set, the "
"system will raise an error when attempting to create LLM routers. Other "
"specialized LLM configurations (coder, nano, embedding) will fall back to "
"this key if their specific keys are not provided."
msgstr ""
"This is the primary API key used for most LLM operations. If not set, the "
"system will raise an error when attempting to create LLM routers. Other "
"specialized LLM configurations (coder, nano, embedding) will fall back to "
"this key if their specific keys are not provided."

#: agentsociety2.config.Config.LLM_API_BASE:1 of
msgid "Base URL endpoint for the default LLM API service."
msgstr "Base URL endpoint for the default LLM API service."

#: agentsociety2.config.Config.LLM_API_BASE:3 of
msgid ""
"Environment variable: AGENTSOCIETY_LLM_API_BASE Default: "
"\"https://api.openai.com/v1\""
msgstr ""
"Environment variable: AGENTSOCIETY_LLM_API_BASE Default: "
"\"https://api.openai.com/v1\""

#: agentsociety2.config.Config.LLM_API_BASE:6 of
msgid ""
"This should point to the API endpoint expected by the selected LiteLLM "
"provider. For OpenAI-compatible gateways, include the protocol (https://) "
"and base path, but not the specific model endpoint (e.g., "
"/chat/completions)."
msgstr ""
"This should point to the API endpoint expected by the selected LiteLLM "
"provider. For OpenAI-compatible gateways, include the protocol (https://) "
"and base path, but not the specific model endpoint (e.g., "
"/chat/completions)."

#: agentsociety2.config.Config.LLM_MODEL:1 of
msgid "Model identifier for the default LLM used in general operations."
msgstr "Model identifier for the default LLM used in general operations."

#: agentsociety2.config.Config.LLM_MODEL:3 of
msgid "Environment variable: AGENTSOCIETY_LLM_MODEL Default: \"gpt-5.5\""
msgstr "Environment variable: AGENTSOCIETY_LLM_MODEL Default: \"gpt-5.5\""

#: agentsociety2.config.Config.LLM_MODEL:6 of
msgid ""
"This model is used for most language understanding and generation tasks that"
" don't require specialized models. The model name should match the LiteLLM "
"provider/model id used by your API provider; \"gpt-5.5\" is only the default"
" OpenAI example."
msgstr ""
"This model is used for most language understanding and generation tasks that"
" don't require specialized models. The model name should match the LiteLLM "
"provider/model id used by your API provider; \"gpt-5.5\" is only the default"
" OpenAI example."

#: agentsociety2.config.Config.CODER_LLM_API_KEY:1 of
msgid "API key for the code generation LLM service."
msgstr "API key for the code generation LLM service."

#: agentsociety2.config.Config.CODER_LLM_API_KEY:3 of
msgid ""
"Environment variable: AGENTSOCIETY_CODER_LLM_API_KEY Default: Falls back to "
"LLM_API_KEY if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_CODER_LLM_API_KEY Default: Falls back to "
"LLM_API_KEY if not set"

#: agentsociety2.config.Config.CODER_LLM_API_KEY:6 of
msgid ""
"This key is used specifically for code-related operations. If not provided, "
"the system will use the default LLM_API_KEY. Setting a separate key allows "
"you to use a different API provider or account for code generation tasks, "
"which may have different rate limits or pricing structures."
msgstr ""
"This key is used specifically for code-related operations. If not provided, "
"the system will use the default LLM_API_KEY. Setting a separate key allows "
"you to use a different API provider or account for code generation tasks, "
"which may have different rate limits or pricing structures."

#: agentsociety2.config.Config.CODER_LLM_API_BASE:1 of
msgid "Base URL endpoint for the code generation LLM API."
msgstr "Base URL endpoint for the code generation LLM API."

#: agentsociety2.config.Config.CODER_LLM_API_BASE:3 of
msgid ""
"Environment variable: AGENTSOCIETY_CODER_LLM_API_BASE Default: Falls back to"
" LLM_API_BASE if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_CODER_LLM_API_BASE Default: Falls back to"
" LLM_API_BASE if not set"

#: agentsociety2.config.Config.CODER_LLM_API_BASE:6 of
msgid ""
"Allows you to use a different API endpoint specifically for code generation "
"tasks. This is useful if you want to route code generation requests to a "
"different service or region for better performance or cost optimization."
msgstr ""
"Allows you to use a different API endpoint specifically for code generation "
"tasks. This is useful if you want to route code generation requests to a "
"different service or region for better performance or cost optimization."

#: agentsociety2.config.Config.CODER_LLM_MODEL:1 of
msgid "Model identifier for code generation and programming tasks."
msgstr "Model identifier for code generation and programming tasks."

#: agentsociety2.config.Config.CODER_LLM_MODEL:3 of
msgid ""
"Environment variable: AGENTSOCIETY_CODER_LLM_MODEL Default: Falls back to "
"LLM_MODEL if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_CODER_LLM_MODEL Default: Falls back to "
"LLM_MODEL if not set"

#: agentsociety2.config.Config.CODER_LLM_MODEL:6 of
msgid ""
"This model is specifically used for code generation, code analysis, and "
"other programming-related operations. Choose a model that is optimized for "
"code understanding and generation, such as models trained on codebases."
msgstr ""
"This model is specifically used for code generation, code analysis, and "
"other programming-related operations. Choose a model that is optimized for "
"code understanding and generation, such as models trained on codebases."

#: agentsociety2.config.Config.NANO_LLM_API_KEY:1 of
msgid "API key for the nano LLM service used in high-frequency operations."
msgstr "API key for the nano LLM service used in high-frequency operations."

#: agentsociety2.config.Config.NANO_LLM_API_KEY:3 of
msgid ""
"Environment variable: AGENTSOCIETY_NANO_LLM_API_KEY Default: Falls back to "
"LLM_API_KEY if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_NANO_LLM_API_KEY Default: Falls back to "
"LLM_API_KEY if not set"

#: agentsociety2.config.Config.NANO_LLM_API_KEY:6 of
msgid ""
"The nano LLM is used for operations that require frequent, fast responses "
"such as memory operations, quick decision-making, and low-latency tasks. "
"Setting a separate key allows you to use a faster or cheaper model for these"
" high-frequency operations."
msgstr ""
"The nano LLM is used for operations that require frequent, fast responses "
"such as memory operations, quick decision-making, and low-latency tasks. "
"Setting a separate key allows you to use a faster or cheaper model for these"
" high-frequency operations."

#: agentsociety2.config.Config.NANO_LLM_API_BASE:1 of
msgid "Base URL endpoint for the nano LLM API."
msgstr "Base URL endpoint for the nano LLM API."

#: agentsociety2.config.Config.NANO_LLM_API_BASE:3 of
msgid ""
"Environment variable: AGENTSOCIETY_NANO_LLM_API_BASE Default: Falls back to "
"LLM_API_BASE if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_NANO_LLM_API_BASE Default: Falls back to "
"LLM_API_BASE if not set"

#: agentsociety2.config.Config.NANO_LLM_API_BASE:6 of
msgid ""
"Allows routing high-frequency operations to a different endpoint, which may "
"be optimized for low latency or located in a different geographic region for"
" better response times."
msgstr ""
"Allows routing high-frequency operations to a different endpoint, which may "
"be optimized for low latency or located in a different geographic region for"
" better response times."

#: agentsociety2.config.Config.NANO_LLM_MODEL:1 of
msgid "Model identifier for high-frequency, low-latency operations."
msgstr "Model identifier for high-frequency, low-latency operations."

#: agentsociety2.config.Config.NANO_LLM_MODEL:3 of
msgid "Environment variable: AGENTSOCIETY_NANO_LLM_MODEL Default: \"gpt-5.5\""
msgstr "Environment variable: AGENTSOCIETY_NANO_LLM_MODEL Default: \"gpt-5.5\""

#: agentsociety2.config.Config.NANO_LLM_MODEL:6 of
msgid ""
"This model is used for operations that require fast responses, such as "
"memory retrieval, quick reasoning, and other tasks where latency is "
"critical. Typically, you might choose a smaller or faster model for these "
"operations to reduce response time."
msgstr ""
"This model is used for operations that require fast responses, such as "
"memory retrieval, quick reasoning, and other tasks where latency is "
"critical. Typically, you might choose a smaller or faster model for these "
"operations to reduce response time."

#: agentsociety2.config.Config.ANALYSIS_LLM_API_KEY:1 of
msgid "API key for the analysis LLM service."
msgstr "API key for the analysis LLM service."

#: agentsociety2.config.Config.ANALYSIS_LLM_API_KEY:3 of
msgid ""
"Environment variable: AGENTSOCIETY_ANALYSIS_LLM_API_KEY Default: Falls back "
"to LLM_API_KEY if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_ANALYSIS_LLM_API_KEY Default: Falls back "
"to LLM_API_KEY if not set"

#: agentsociety2.config.Config.ANALYSIS_LLM_API_KEY:6 of
msgid ""
"This key is used specifically for data analysis, insight generation, and "
"report writing tasks. Setting a separate key allows you to use a more "
"capable model for these complex reasoning tasks."
msgstr ""
"This key is used specifically for data analysis, insight generation, and "
"report writing tasks. Setting a separate key allows you to use a more "
"capable model for these complex reasoning tasks."

#: agentsociety2.config.Config.ANALYSIS_LLM_API_BASE:1 of
msgid "Base URL endpoint for the analysis LLM API."
msgstr "Base URL endpoint for the analysis LLM API."

#: agentsociety2.config.Config.ANALYSIS_LLM_API_BASE:3 of
msgid ""
"Environment variable: AGENTSOCIETY_ANALYSIS_LLM_API_BASE Default: Falls back"
" to LLM_API_BASE if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_ANALYSIS_LLM_API_BASE Default: Falls back"
" to LLM_API_BASE if not set"

#: agentsociety2.config.Config.ANALYSIS_LLM_API_BASE:6 of
msgid ""
"Allows you to use a different API endpoint specifically for analysis tasks. "
"This is useful if you want to route analysis requests to a more capable "
"model or a different service."
msgstr ""
"Allows you to use a different API endpoint specifically for analysis tasks. "
"This is useful if you want to route analysis requests to a more capable "
"model or a different service."

#: agentsociety2.config.Config.ANALYSIS_LLM_MODEL:1 of
msgid "Model identifier for data analysis and report generation tasks."
msgstr "Model identifier for data analysis and report generation tasks."

#: agentsociety2.config.Config.ANALYSIS_LLM_MODEL:3 of
msgid ""
"Environment variable: AGENTSOCIETY_ANALYSIS_LLM_MODEL Default: Falls back to"
" LLM_MODEL if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_ANALYSIS_LLM_MODEL Default: Falls back to"
" LLM_MODEL if not set"

#: agentsociety2.config.Config.ANALYSIS_LLM_MODEL:6 of
msgid ""
"This model is specifically used for data analysis, insight generation, "
"visualization planning, and report writing. Choose a model with strong "
"reasoning and writing capabilities for best results."
msgstr ""
"This model is specifically used for data analysis, insight generation, "
"visualization planning, and report writing. Choose a model with strong "
"reasoning and writing capabilities for best results."

#: agentsociety2.config.Config.EMBEDDING_API_KEY:1 of
msgid "API key for the embedding model service."
msgstr "API key for the embedding model service."

#: agentsociety2.config.Config.EMBEDDING_API_KEY:3 of
msgid ""
"Environment variable: AGENTSOCIETY_EMBEDDING_API_KEY Default: Falls back to "
"LLM_API_KEY if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_EMBEDDING_API_KEY Default: Falls back to "
"LLM_API_KEY if not set"

#: agentsociety2.config.Config.EMBEDDING_API_KEY:6 of
msgid ""
"This key is used specifically for embedding operations, which convert text "
"into high-dimensional vectors for semantic search, similarity matching, and "
"memory operations. Some providers offer separate embedding services with "
"different pricing."
msgstr ""
"This key is used specifically for embedding operations, which convert text "
"into high-dimensional vectors for semantic search, similarity matching, and "
"memory operations. Some providers offer separate embedding services with "
"different pricing."

#: agentsociety2.config.Config.EMBEDDING_API_BASE:1 of
msgid "Base URL endpoint for the embedding API service."
msgstr "Base URL endpoint for the embedding API service."

#: agentsociety2.config.Config.EMBEDDING_API_BASE:3 of
msgid ""
"Environment variable: AGENTSOCIETY_EMBEDDING_API_BASE Default: Falls back to"
" LLM_API_BASE if not set"
msgstr ""
"Environment variable: AGENTSOCIETY_EMBEDDING_API_BASE Default: Falls back to"
" LLM_API_BASE if not set"

#: agentsociety2.config.Config.EMBEDDING_API_BASE:6 of
msgid ""
"Allows you to use a different API endpoint specifically for embedding "
"operations. Some providers have dedicated embedding endpoints that may offer"
" better performance or different pricing models for embedding tasks."
msgstr ""
"Allows you to use a different API endpoint specifically for embedding "
"operations. Some providers have dedicated embedding endpoints that may offer"
" better performance or different pricing models for embedding tasks."

#: agentsociety2.config.Config.EMBEDDING_MODEL:1 of
msgid "Model identifier for text embedding generation."
msgstr "Model identifier for text embedding generation."

#: agentsociety2.config.Config.EMBEDDING_MODEL:3 of
msgid ""
"Environment variable: AGENTSOCIETY_EMBEDDING_MODEL Default: \"text-"
"embedding-3-large\""
msgstr ""
"Environment variable: AGENTSOCIETY_EMBEDDING_MODEL Default: \"text-"
"embedding-3-large\""

#: agentsociety2.config.Config.EMBEDDING_MODEL:6 of
msgid ""
"This model is used to convert text into dense vector representations "
"(embeddings). The embeddings are used for semantic search, similarity "
"matching, and storing memories in vector databases. Choose a model that "
"produces high-quality embeddings for your use case and language."
msgstr ""
"This model is used to convert text into dense vector representations "
"(embeddings). The embeddings are used for semantic search, similarity "
"matching, and storing memories in vector databases. Choose a model that "
"produces high-quality embeddings for your use case and language."

#: agentsociety2.config.Config.EMBEDDING_DIMS:1 of
msgid ""
"Dimensionality of the embedding vectors produced by the embedding model."
msgstr ""
"Dimensionality of the embedding vectors produced by the embedding model."

#: agentsociety2.config.Config.EMBEDDING_DIMS:3 of
msgid "Environment variable: AGENTSOCIETY_EMBEDDING_DIMS Default: 1024"
msgstr "Environment variable: AGENTSOCIETY_EMBEDDING_DIMS Default: 1024"

#: agentsociety2.config.Config.EMBEDDING_DIMS:6 of
msgid ""
"This specifies the size of the vector space for embeddings. Higher "
"dimensions can capture more nuanced semantic information but require more "
"storage and computation. The value must match the actual output "
"dimensionality of the selected embedding model. Common values are 384, 512, "
"768, 1024, or 1536 depending on the model."
msgstr ""
"This specifies the size of the vector space for embeddings. Higher "
"dimensions can capture more nuanced semantic information but require more "
"storage and computation. The value must match the actual output "
"dimensionality of the selected embedding model. Common values are 384, 512, "
"768, 1024, or 1536 depending on the model."

#: agentsociety2.config.Config.LITERATURE_SEARCH_API_URL:1 of
