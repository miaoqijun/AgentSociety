#: agentsociety2.config.Config.CODER_LLM_API_BASE:1 of
msgid "Base URL endpoint for the code generation LLM API."
msgstr ""

#: agentsociety2.config.Config.CODER_LLM_API_BASE:3 of
msgid ""
"Environment variable: AGENTSOCIETY_CODER_LLM_API_BASE Default: Falls back"
" to LLM_API_BASE if not set"
msgstr ""

#: agentsociety2.config.Config.CODER_LLM_API_BASE:6 of
