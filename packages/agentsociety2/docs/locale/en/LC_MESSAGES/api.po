msgstr ""
"This class exposes configuration items in the form of \"class "
"attributes\" for easy reading without instantiation."

#: agentsociety2.config.config.Config:5 of
msgid "主要环境变量（节选）："
msgstr "Main environment variables (excerpt):"

#: agentsociety2.config.config.Config:7 of
