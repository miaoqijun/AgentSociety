#: agentsociety2.backend.routers.agent_skills.list_skills:1 of
msgid "列出所有已发现的 Agent Skill（builtin + custom + env）。"
msgstr "List all discovered Agent Skills (builtin + custom + env)."

#: agentsociety2.backend.routers.agent_skills.enable_skill:1 of
msgid "启用指定 skill（全局注册表；PersonAgent 在下一仿真步会与全局对齐）。"
msgstr ""
"Enables the specified skill (global registry; PersonAgent will be globally "
"aligned in the next simulation step)."

#: agentsociety2.backend.routers.agent_skills.disable_skill:1 of
msgid "禁用指定 skill（内置技能不可关闭）。"
msgstr "Disable the specified skill (built-in skills cannot be turned off)."

#: agentsociety2.backend.routers.agent_skills.scan_custom_skills:1 of
#, python-brace-format
msgid "扫描工作区的自定义 Agent Skill（{workspace}/custom/skills/）。"
msgstr ""
"Scan the workspace for custom Agent Skills ({workspace}/custom/skills/)."

#: agentsociety2.backend.routers.agent_skills.import_skill:1 of
msgid "从外部路径导入 Agent Skill（复制到 custom/skills/）。"
msgstr "Import Agent Skills from an external path (copied to custom/skills/)."

#: agentsociety2.backend.routers.agent_skills.create_skill:1 of
msgid "在线创建新的自定义 Skill。"
msgstr "Create new custom skills online."

#: agentsociety2.backend.routers.agent_skills.create_skill:3 of
#, python-brace-format
msgid "在 custom/skills/{name}/ 下生成 SKILL.md（+ 可选脚本文件）。"
msgstr ""
"Generate SKILL.md (+ optional script file) under custom/skills/{name}/."

#: agentsociety2.backend.routers.agent_skills.upload_skill:1 of
msgid "上传 zip 包导入 Skill。"
msgstr "Upload the zip package to import Skill."

#: agentsociety2.backend.routers.agent_skills.upload_skill:3 of
msgid "zip 包应包含一个顶层目录，内含 SKILL.md。"
msgstr ""
"The zip package should contain a top-level directory containing SKILL.md."

#: agentsociety2.backend.routers.agent_skills.reload_skill:1 of
msgid "热重载指定 Skill 的 SKILL.md 元数据。"
msgstr "Hot reload specifies the Skill's SKILL.md metadata."

#: agentsociety2.backend.routers.agent_skills.get_skill_info:1 of
msgid "获取 Skill 的详细信息（含 SKILL.md 内容）。"
msgstr "Get Skill details (including SKILL.md content)."

#: agentsociety2.backend.routers.agent_skills.remove_custom_skill:1 of
msgid "移除自定义 Skill（删除目录 + 注册表记录）。仅限 source=custom。"
msgstr ""
"Remove custom Skill (delete directory + registry record). Only "
"source=custom."

