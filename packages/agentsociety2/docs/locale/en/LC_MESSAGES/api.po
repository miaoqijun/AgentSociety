msgstr ""

#: agentsociety2.storage.replay_sink.ReplaySink.register_table:1 of
msgid "Record a table's schema in ``_schema.json`` (idempotent)."
msgstr ""

#: agentsociety2.storage.replay_sink.ReplaySink.register_dataset:1 of
msgid "Record a dataset + its columns in ``_schema.json`` (idempotent)."
msgstr ""

#: agentsociety2.storage.replay_sink.ReplaySink.close:1 of
msgid "Close all open shard fds."
msgstr ""

