#: ../../api/backend.rst:38
msgid "自定义模块路由"
msgstr "Custom Module Routes"

#: agentsociety2.backend.routers.custom:1 of
msgid "自定义模块 API 路由"
msgstr "Custom Module API Routes"

#: agentsociety2.backend.routers.custom:3 of
msgid "提供扫描、清理、测试自定义模块的 API 端点。"
msgstr "Provides API endpoints for scanning, cleaning, and testing custom modules."

#: agentsociety2.backend.routers.custom:5 of
msgid ""
"关联文件： - @extension/src/projectStructureProvider.ts - 前端项目结构视图（调用此API） - "
"@extension/src/apiClient.ts - API客户端"
msgstr ""
"Related files: - @extension/src/projectStructureProvider.ts - frontend "
"project structure view that calls this API - @extension/src/apiClient.ts "
"- API client"

#: agentsociety2.backend.routers.custom:9 of
msgid ""
"API端点： - POST /api/v1/custom/scan - 扫描自定义模块并生成JSON配置 - POST "
"/api/v1/custom/clean - 清理自定义模块配置 - POST /api/v1/custom/test - 测试自定义模块 - "
"GET /api/v1/custom/list - 列出已注册的自定义模块 - GET /api/v1/custom/status - "
"获取自定义模块状态"
msgstr ""
"API endpoints: - POST /api/v1/custom/scan - scan custom modules and "
"generate JSON configuration - POST /api/v1/custom/clean - clean custom "
"module configuration - POST /api/v1/custom/test - test custom modules - "
"GET /api/v1/custom/list - list registered custom modules - GET "
"/api/v1/custom/status - get custom module status"

#: agentsociety2.backend.routers.custom:16 of
msgid ""
"内部服务： - "
"@packages/agentsociety2/agentsociety2/backend/services/custom/scanner.py "
"- 模块扫描 - "
"@packages/agentsociety2/agentsociety2/backend/services/custom/generator.py"
" - JSON生成 - @packages/agentsociety2/agentsociety2/registry/ - 模块注册表"
msgstr ""
"Internal services: - "
"@packages/agentsociety2/agentsociety2/backend/services/custom/scanner.py "
"- module scanning - "
"@packages/agentsociety2/agentsociety2/backend/services/custom/generator.py"
" - JSON generation - @packages/agentsociety2/agentsociety2/registry/ - "
"module registry"

#: agentsociety2.backend.routers.custom.ScanRequest:1 of
msgid "扫描请求"
msgstr "Scan Request"

#: agentsociety2.backend.routers.custom.ScanResponse:1 of
msgid "扫描响应"
msgstr "Scan Response"

#: agentsociety2.backend.routers.custom.CleanResponse:1 of
msgid "清理响应"
msgstr "Clean Response"

#: agentsociety2.backend.routers.custom.TestRequest:1 of
msgid "测试请求"
msgstr "Test Request"

#: agentsociety2.backend.routers.custom.ModuleTestResult:1 of
msgid "单个模块测试结果"
msgstr "Single Module Test Result"

#: agentsociety2.backend.routers.custom.TestResponse:1 of
msgid "测试响应"
msgstr "Test Response"

#: agentsociety2.backend.routers.custom.ListResponse:1 of
msgid "列表响应"
msgstr "List Response"

#: agentsociety2.backend.routers.custom.scan_custom_modules:1 of
msgid "扫描自定义模块并注册到内存"
msgstr "Scan custom modules and register them in memory"

#: agentsociety2.backend.routers.custom.scan_custom_modules:3 of
msgid ""
"扫描工作区的 custom/agents/ 和 custom/envs/ 目录（跳过 examples/ 子目录）， "
"验证发现的模块并将其直接注册到内存中的 registry。"
msgstr ""
"Scans the workspace directories custom/agents/ and custom/envs/ while "
"skipping the examples/ subdirectories, validates discovered modules, and "
"registers them directly in the in-memory registry."

#: agentsociety2.backend.routers.custom.scan_custom_modules:6 of
msgid "扫描请求，包含： - workspace_path: 工作区路径（可选，不提供则使用环境变量）"
msgstr ""
"Scan request, including: - workspace_path: workspace path, optional; if "
"omitted, the environment variable is used"

#: agentsociety2.backend.routers.custom.scan_custom_modules:8 of
msgid ""
"ScanResponse: 扫描结果，包含： - success: 是否成功 - agents_found: 发现的Agent数量 - "
"envs_found: 发现的环境模块数量 - agents_generated: 成功注册的Agent数量 - envs_generated: "
"成功注册的环境模块数量 - errors: 错误信息列表 - message: 结果消息"
msgstr ""
"ScanResponse: Scan result, including: - success: whether the operation "
"succeeded - agents_found: number of discovered Agents - envs_found: "
"number of discovered environment modules - agents_generated: number of "
"successfully registered Agents - envs_generated: number of successfully "
"registered environment modules - errors: list of error messages - "
"message: result message"

#: agentsociety2.backend.routers.custom.clean_custom_modules:8
#: agentsociety2.backend.routers.custom.scan_custom_modules:9
#: agentsociety2.backend.routers.custom.test_custom_modules:8 of
msgid "400 - 未提供工作区路径"
msgstr "400 - Workspace path was not provided"

#: agentsociety2.backend.routers.custom.scan_custom_modules:10 of
msgid "500 - 扫描失败"
msgstr "500 - Scan failed"

#: agentsociety2.backend.routers.custom.scan_custom_modules:14 of
msgid "此接口不会生成JSON配置文件，模块仅注册到内存中。 如需持久化配置，请使用 /api/v1/custom/classes 端点。"
msgstr ""
"This endpoint does not generate JSON configuration files. Modules are "
"registered only in memory. To persist the configuration, use the "
"/api/v1/custom/classes endpoint."

#: agentsociety2.backend.routers.custom.clean_custom_modules:1 of
msgid "清理自定义模块的JSON配置"
msgstr "Clean JSON configuration for custom modules"

#: agentsociety2.backend.routers.custom.clean_custom_modules:3 of
msgid "删除所有标记为 is_custom=true 的JSON配置文件。"
msgstr "Deletes all JSON configuration files marked with is_custom=true."

#: agentsociety2.backend.routers.custom.clean_custom_modules:5 of
msgid "清理请求，包含： - workspace_path: 工作区路径（可选）"
msgstr "Clean request, including: - workspace_path: workspace path, optional"

#: agentsociety2.backend.routers.custom.clean_custom_modules:7 of
msgid ""
"CleanResponse: 清理结果，包含： - success: 是否成功 - removed_count: 删除的配置数量 - "
"message: 结果消息"
msgstr ""
"CleanResponse: Clean result, including: - success: whether the operation "
"succeeded - removed_count: number of removed configurations - message: "
"result message"

#: agentsociety2.backend.routers.custom.clean_custom_modules:9 of
msgid "500 - 清理失败"
msgstr "500 - Cleanup failed"

#: agentsociety2.backend.routers.custom.test_custom_modules:1 of
msgid "测试自定义模块"
msgstr "Test custom modules"

#: agentsociety2.backend.routers.custom.test_custom_modules:3 of
msgid "扫描并测试自定义模块，验证其能否正常工作。可以测试所有模块或指定特定模块。"
msgstr ""
"Scans and tests custom modules to verify that they work correctly. It can"
" test all modules or a specific module."

#: agentsociety2.backend.routers.custom.test_custom_modules:5 of
msgid ""
"测试请求，包含： - workspace_path: 工作区路径（可选） - module_kind: 模块类型 ('agent' 或 "
"'env_module'，可选） - module_class_name: 要测试的类名（与module_kind配合使用，可选）"
msgstr ""
"Test request, including: - workspace_path: workspace path, optional - "
"module_kind: module kind ('agent' or 'env_module'), optional - "
"module_class_name: class name to test, used together with module_kind and"
" optional"

#: agentsociety2.backend.routers.custom.test_custom_modules:7 of
msgid ""
"TestResponse: 测试结果，包含： - success: 是否全部通过 - test_output: 测试输出内容 - error: "
"错误信息（如有） - returncode: 测试进程返回码 - results: 各模块测试结果列表 - total_tests: 总测试数 -"
" passed_tests: 通过数 - failed_tests: 失败数"
msgstr ""
"TestResponse: Test result, including: - success: whether all tests passed"
" - test_output: test output content - error: error message, if any - "
"returncode: return code of the test process - results: list of test "
"results for each module - total_tests: total number of tests - "
"passed_tests: number of passed tests - failed_tests: number of failed "
"tests"

#: agentsociety2.backend.routers.custom.test_custom_modules:9 of
msgid "500 - 测试失败"
msgstr "500 - Test failed"

#: agentsociety2.backend.routers.custom.test_custom_modules:11 of
msgid "如果不指定 module_kind 和 module_class_name，则测试所有发现的模块。"
msgstr ""
"If module_kind and module_class_name are not specified, all discovered "
"modules are tested."

#: agentsociety2.backend.routers.custom.list_custom_modules:1 of
msgid "列出当前已注册的自定义模块"
msgstr "List currently registered custom modules"

#: agentsociety2.backend.routers.custom.list_custom_modules:3 of
