#: agentsociety2.agent.person.PersonAgent.__init__:12 of
msgid ""
"``system_prompt_max_identity_chars``：Agent Identity JSON 总长度上限（默认 10000）"
msgstr ""
"``system_prompt_max_identity_chars``: The upper limit of the total length of"
" Agent Identity JSON (default 10000)"

#: agentsociety2.agent.person.PersonAgent.__init__:13 of
msgid ""
"``workspace_read_chunk_chars``：``workspace_read`` / ``read_skill`` "
"单段最大字符数（默认 32000，允许 1024–96000）"
msgstr ""
"``workspace_read_chunk_chars``: ``workspace_read`` / ``read_skill`` Maximum "
"number of characters in a single paragraph (default 32000, allowed "
"1024–96000)"

#: agentsociety2.agent.person.PersonAgent.__init__:14 of
msgid ""
"``tool_result_thread_budget_chars``：单条 TOOL_RESULT_JSON 序列化预算（默认 65536）"
msgstr ""
"``tool_result_thread_budget_chars``: Single TOOL_RESULT_JSON serialization "
"budget (default 65536)"

#: agentsociety2.agent.person.PersonAgent.__init__:15 of
msgid ""
"``profile_max_chars`` / ``profile_truncate_chars``：profile 写入 Identity "
"前的截断上限（默认 4000）"
msgstr ""
