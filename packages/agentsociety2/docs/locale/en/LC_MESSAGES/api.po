msgstr "``unit``: Optional unit string used by analysis and reporting."

#: agentsociety2.storage.table_schema.ColumnDef:14 of
msgid "``enum_values``：可选，离散列的枚举值列表。"
msgstr "``enum_values``: Optional list of enumeration values for discrete columns."

#: agentsociety2.storage.table_schema.ColumnDef:15 of
msgid "``example``：可选，示例值。"
msgstr "``example``: Optional example value."

#: agentsociety2.storage.table_schema.ColumnDef:16 of
msgid "``tags``：可选，自由标签列表。"
msgstr "``tags``: Optional free-form tag list."

