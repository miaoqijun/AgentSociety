msgstr "Time span of this step (seconds)."

#: agentsociety2.env.base.EnvBase.step:4
#: agentsociety2.env.router_base.RouterBase.step:4 of
msgid "本步结束后的仿真时间。"
msgstr "The simulation time after the end of this step."

#: agentsociety2.env.router_base.RouterBase.close:1 of
msgid "关闭路由器（关闭所有环境模块）。"
msgstr "Shut down the router (turn off all environment modules)."

#: agentsociety2.env.router_base.RouterBase.get_tool_call_history:1 of
msgid "汇总所有环境模块的工具调用历史（按时间排序）。"
msgstr ""
"Summarize tool call history for all environment modules (sorted by time)."

#: agentsociety2.env.router_base.RouterBase.get_tool_call_history:3 of
msgid "调用记录列表（按 ``timestamp`` 升序）。"
msgstr "Recall the record list (in ascending order by ``timestamp``)."

#: agentsociety2.env.router_base.RouterBase.reset_tool_call_history:1 of
msgid "清空所有环境模块的工具调用历史。"
msgstr "Clear the tool call history of all environment modules."

#: agentsociety2.env.router_base.RouterBase.set_replay_writer:1 of
msgid "为所有环境模块设置回放写入器。"
msgstr "Set replay writers for all environment modules."

#: agentsociety2.env.base.EnvBase.set_replay_writer:3
#: agentsociety2.env.router_base.RouterBase.set_replay_writer:3 of
msgid ":class:`~agentsociety2.storage.ReplayWriter` 实例。"
msgstr ":class:`~agentsociety2.storage.ReplayWriter` Example."

#: agentsociety2.env.router_base.RouterBase.get_system_prompt:1 of
msgid "构建 router 侧的通用 system prompt（不含具体任务指令）。"
msgstr ""
"Build a general system prompt on the router side (without specific task "
"instructions)."

#: agentsociety2.env.router_base.RouterBase.acompletion:1 of
msgid "封装 LiteLLM Router 的 acompletion（含重试与 token 统计）。"
msgstr ""
"Encapsulates the acompletion of LiteLLM Router (including retry and token "
"statistics)."

#: agentsociety2.env.router_base.RouterBase.acompletion:3
#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:3
#: agentsociety2.env.router_base.RouterBase.acompletion_with_system_prompt:3
#: of
msgid "``coder`` 或 ``summary``。"
msgstr "``coder`` or ``summary``."

#: agentsociety2.env.router_base.RouterBase.acompletion:4 of
msgid ""
"消息列表（不自动追加 system prompt；若需要请用 :meth:`acompletion_with_system_prompt`）。"
msgstr ""
"Message list (system prompt is not automatically appended; please use "
":meth:`acompletion_with_system_prompt` if necessary)."

#: agentsociety2.env.router_base.RouterBase.acompletion:5 of
msgid "是否流式返回。"
msgstr "Whether to stream returns."

#: agentsociety2.env.router_base.RouterBase.acompletion:6 of
msgid "可选。最大重试次数；为空则使用 ``self.max_llm_call_retry``。"
msgstr ""
"Optional. Maximum number of retries; if empty, use "
"``self.max_llm_call_retry``."

#: agentsociety2.env.router_base.RouterBase.acompletion:7 of
msgid "429 类错误的指数退避基准延迟。"
msgstr "Exponential backoff benchmark latency for class 429 errors."

#: agentsociety2.env.router_base.RouterBase.acompletion:8
#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:8
#: of
msgid "指数退避最大延迟。"
msgstr "Exponential backoff maximum delay."

#: agentsociety2.env.router_base.RouterBase.acompletion:9 of
msgid "LLM 响应对象（stream=False 时为 :class:`litellm.types.utils.ModelResponse`）。"
msgstr ""
"LLM response object (:class:`litellm.types.utils.ModelResponse` when "
"stream=False)."

#: agentsociety2.env.router_base.RouterBase.acompletion:10 of
msgid "超过重试次数仍失败时抛出。"
msgstr "Thrown when the number of retries is exceeded and still fails."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_system_prompt:1
#: of
msgid "发送补全请求并自动在最前追加 router system prompt。"
msgstr ""
"Send a completion request and automatically append the router system prompt "
"at the front."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_system_prompt:4
#: of
msgid "消息列表。"
msgstr "Message list."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:1
#: of
msgid "发送补全并校验为指定 Pydantic 模型（失败时自动反馈并重试）。"
msgstr ""
"Send completion and verify to the specified Pydantic model (automatic "
"feedback and retry on failure)."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:4
#: of
msgid "用于校验的 Pydantic 模型类型。"
msgstr "Pydantic model type used for validation."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:5
#: of
msgid "消息列表（会自动追加 system prompt）。"
msgstr "Message list (system prompt will be automatically appended)."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:6
#: of
msgid "最大重试次数（不含首次尝试）。"
msgstr "Maximum number of retries (excluding first attempt)."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:7
#: of
msgid "429 类错误指数退避基准延迟。"
msgstr "Class 429 error exponential backoff benchmark delay."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:9
#: of
#, python-brace-format
msgid "可选。自定义错误反馈模板（需包含 ``{error_message}`` 与 ``{model_schema}`` 占位符）。"
msgstr ""
"Optional. Customize error feedback template (need to contain "
"``{error_message}`` and ``{model_schema}`` placeholders)."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:10
#: of
msgid "校验通过的 Pydantic 实例。"
msgstr "A Pydantic instance that passes validation."

#: agentsociety2.env.router_base.RouterBase.acompletion_with_pydantic_validation:11
#: of
msgid "解析/校验在重试后仍失败时抛出。"
msgstr "Thrown when parsing/verification fails after retries."

#: agentsociety2.env.router_base.RouterBase.dump:1 of
msgid ""
"Dump router state to a serializable dict. Subclasses should override this to"
" include router-specific state."
msgstr ""
"Dump router state to a serializable dict. Subclasses should override this to"
" include router-specific state."

#: agentsociety2.env.router_base.RouterBase.load:1 of
msgid ""
"Load router state from a dict produced by dump(). Subclasses should override"
" this to restore router-specific state."
msgstr ""
"Load router state from a dict produced by dump(). Subclasses should override"
" this to restore router-specific state."

#: agentsociety2.env.router_base.RouterBase.get_status_descriptions:1 of
msgid "Get standard status descriptions."
msgstr "Get standard status descriptions."

#: agentsociety2.env.router_base.RouterBase.get_status_descriptions:3 of
msgid ""
"The status indicates whether the user's instruction has been effectively "
"completed in the environment modules, or needs to wait for some time before "
"the user actively checks completion."
msgstr ""
"The status indicates whether the user's instruction has been effectively "
"completed in the environment modules, or needs to wait for some time before "
"the user actively checks completion."

#: agentsociety2.env.router_base.RouterBase.get_status_descriptions:7 of
msgid ""
"Dictionary mapping status values to their descriptions: - success: The task "
"has been completed successfully. All required operations finished without "
"errors. - in_progress: The task is still being executed or more steps are "
"needed. The agent need to check whether it is done in the next steps. - "
"fail: The task could not be completed (e.g., unsupported instruction, "
"missing data, invalid input). Include detailed reason in results. - error: "
"An error occurred during code execution. Must include error details in "
"results['error']. - unknown: Execution status unknown"
msgstr ""
"Dictionary mapping status values to their descriptions: - success: The task "
"has been completed successfully. All required operations finished without "
"errors. - in_progress: The task is still being executed or more steps are "
"needed. The agent need to check whether it is done in the next steps. - "
"fail: The task could not be completed (e.g., unsupported instruction, "
"missing data, invalid input). Include detailed reason in results. - error: "
"An error occurred during code execution. Must include error details in "
"results['error']. - unknown: Execution status unknown"

#: agentsociety2.env.router_base.RouterBase.get_world_description:1 of
msgid "Get the world description."
msgstr "Get the world description."

#: agentsociety2.env.router_base.RouterBase.generate_world_description_from_tools:1
#: of
msgid "根据环境路由器的所有工具信息（包括可写和只读工具），使用LLM生成世界描述文本。"
msgstr ""
"Use LLM to generate world description text based on all tool information of "
"the environment router (including writable and read-only tools)."

#: agentsociety2.env.router_base.RouterBase.generate_world_description_from_tools:3
#: of
msgid ""
"这个函数将工具信息转换为对PersonAgent有用的world_description，帮助agent理解： 1. 环境中可用的模块和工具 2. "
"如何通过自然语言指令与router交互 3. 每个工具的功能和用途 4. 如何正确使用这些工具来实现目标"
msgstr ""
"This function converts the tool information into a useful world_description "
"for the PersonAgent, helping the agent understand: 1. The modules and tools "
"available in the environment 2. How to interact with the router through "
"natural language instructions 3. The function and purpose of each tool 4. "
"How to use these tools correctly to achieve the goal"

#: agentsociety2.env.router_base.RouterBase.generate_world_description_from_tools:9
#: of
msgid "str: 生成的世界描述文本，可直接作为PersonAgent的world_description参数"
msgstr ""
"str: The generated world description text, which can be directly used as the"
" world_description parameter of PersonAgent"

#: agentsociety2.env.router_base.RouterBase.get_collected_pydantic_models:1 of
msgid "获取已收集的所有 Pydantic BaseModel 类型及其源代码。"
msgstr "Get all collected Pydantic BaseModel types and their source code."

#: agentsociety2.env.router_base.RouterBase.get_collected_pydantic_models:3 of
msgid "这些模型是在调用 _collect_tools_info() 时从工具函数的参数类型和返回值类型中收集的。"
msgstr ""
"These models are collected from the parameter types and return value types "
"of the tool functions when calling _collect_tools_info()."

#: agentsociety2.env.router_base.RouterBase.get_collected_pydantic_models:5 of
msgid "字典，key 是 BaseModel 类型，value 是其源代码"
msgstr "Dictionary, key is BaseModel type, value is its source code"

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:1 of
msgid "根据用户输入和Router输出生成最终答案。"
msgstr "Generate the final answer based on user input and Router output."

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:3 of
msgid ""
"这个方法接收用户输入（ctx, instruction）和Router输出（results和过程文本）， "
"使用LLM总结为一个answer，并确定执行状态。 使用JSON格式返回，通过Pydantic model验证。"
msgstr ""
"This method receives user input (ctx, instruction) and Router output "
"(results and process text), summarizes them into an answer using LLM, and "
"determines the execution status. Returned in JSON format and verified "
"through Pydantic model."

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:7 of
msgid "上下文字典，包含环境变量等信息"
msgstr ""
"Context dictionary, containing information such as environment variables"

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:8 of
msgid "用户的原始指令"
msgstr "User's original instruction"

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:9 of
msgid "Router执行的结果字典"
msgstr "Dictionary of results executed by Router"

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:10 of
msgid "过程文本（可选），描述执行过程的文本信息"
msgstr ""
"Process text (optional), text information describing the execution process"

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:11 of
msgid "初步的执行状态（可能被LLM更新）"
msgstr "Preliminary execution status (may be updated by LLM)"

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:12 of
msgid "错误信息（如果有）"
msgstr "Error message (if any)"

#: agentsociety2.env.router_base.RouterBase.generate_final_answer:14 of
msgid ""
"Tuple[str, str]: (final_answer, determined_status) - final_answer: "
"LLM生成的最终答案（summary文本） - determined_status: "
"确定的执行状态（success/in_progress/fail/error）"
msgstr ""
"Tuple[str, str]: (final_answer, determined_status) - final_answer: the final"
" answer generated by LLM (summary text) - determined_status: determined "
"execution status (success/in_progress/fail/error)"

#: ../../api/env.rst:15
msgid "EnvBase"
msgstr "EnvBase"

#: agentsociety2.env.base.EnvBase:1 of
msgid "环境模块基类。"
msgstr "Environment module base class."

#: agentsociety2.env.base.EnvBase:3 of
msgid "环境模块定义 Agent 可执行的操作和可观察的状态。通过 ``@tool`` 装饰器 注册方法为可调用工具，供 Router 调用。"
msgstr ""
"The environment module defines the actions and observable states that the "
"Agent can perform. Register the method as a callable tool through the "
"``@tool`` decorator for Router to call."

#: agentsociety2.env.base.EnvBase:6 of
msgid "工具类型："
msgstr "Tool type:"

#: agentsociety2.env.base.EnvBase:7 of
msgid "**常规工具**: ``@tool(readonly=False)`` — 可修改环境状态"
msgstr ""
"**常规工具**: ``@tool(readonly=False)`` — Environment status can be modified"

#: agentsociety2.env.base.EnvBase:8 of
msgid "**只读工具**: ``@tool(readonly=True)`` — 仅查询，不修改状态"
msgstr "**只读工具**: ``@tool(readonly=True)`` — Query only, do not modify status"

#: agentsociety2.env.base.EnvBase:9 of
msgid "**观察工具**: ``@tool(readonly=True, kind=\"observe\")`` — 自动调用"
msgstr ""
"**观察工具**: ``@tool(readonly=True, kind=\"observe\")`` — Automatically called"

#: agentsociety2.env.base.EnvBase:10 of
msgid "**统计工具**: ``@tool(readonly=True, kind=\"statistics\")`` — 统计信息"
msgstr "**统计工具**: ``@tool(readonly=True, kind=\"statistics\")`` — Statistics"

#: agentsociety2.env.base.EnvBase:12 of
msgid "子类应实现："
msgstr "Subclasses should implement:"

#: agentsociety2.env.base.EnvBase:13 of
msgid "使用 ``@tool`` 装饰器定义可执行操作"
msgstr "Use the ``@tool`` decorator to define executable operations"

#: agentsociety2.env.base.EnvBase:14 of
msgid "可选：实现 ``observe()`` 方法（默认收集 kind=\"observe\" 的工具）"
msgstr ""
"Optional: Implement the ``observe()`` method (tools that collect "
"kind=\"observe\" by default)"

#: agentsociety2.env.EnvBase.name:1 of
msgid "Name of the environment module"
msgstr "Name of the environment module"

#: agentsociety2.env.EnvBase.description:1 of
msgid ""
"Description of the environment module for router selection and function "
"calling"
msgstr ""
"Description of the environment module for router selection and function "
"calling"

#: agentsociety2.env.base.EnvBase.mcp_description:1 of
msgid ""
"Return a description text for MCP environment module candidate list. This "
"method should be overridden by subclasses to provide a description suitable "
"for MCP server to list available environment modules."
msgstr ""
"Return a description text for MCP environment module candidate list. This "
"method should be overridden by subclasses to provide a description suitable "
"for MCP server to list available environment modules."

#: agentsociety2.env.base.EnvBase.mcp_description:5 of
msgid ""
"A string description of the environment module for MCP registration. The "
"description uses Markdown format and should include the class name, detailed"
" description, initialization parameters when applicable, and an example "
"config or JSON schema when applicable."
msgstr ""
"A string description of the environment module for MCP registration. The "
"description uses Markdown format and should include the class name, detailed"
" description, initialization parameters when applicable, and an example "
"config or JSON schema when applicable."

#: agentsociety2.env.base.EnvBase.get_agent_skills_dirs:1 of
msgid ""
"Return directories containing agent skills provided by this environment "
"module."
msgstr ""
"Return directories containing agent skills provided by this environment "
"module."

#: agentsociety2.env.base.EnvBase.get_agent_skills_dirs:3 of
msgid ""
"This method enables environment modules to bundle specialized skills that "
"agents should use when operating within that environment. Skills are "
"discovered by scanning the returned directories for SKILL.md files."
