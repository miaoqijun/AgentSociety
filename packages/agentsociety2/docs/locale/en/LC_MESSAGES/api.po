msgstr ""
"Template mode (not used by ReActRouter, only compatible with signatures)"

#: agentsociety2.env.router_codegen.CodeGenRouter.ask:8
#: agentsociety2.env.router_plan_execute.PlanExecuteRouter.ask:8
#: agentsociety2.env.router_react.ReActRouter.ask:8 of
