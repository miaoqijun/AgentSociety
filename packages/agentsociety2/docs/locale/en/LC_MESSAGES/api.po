msgid "Model identifier for the default LLM used in general operations."
msgstr ""

#: agentsociety2.config.Config.LLM_MODEL:3 of
msgid "Environment variable: AGENTSOCIETY_LLM_MODEL Default: \"gpt-5.4\""
msgstr ""

#: agentsociety2.config.Config.LLM_MODEL:6 of
