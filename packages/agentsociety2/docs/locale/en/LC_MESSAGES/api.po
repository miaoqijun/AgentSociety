msgstr ""

#: agentsociety2.config.Config.LLM_RAY_CONCURRENCY:1 of
msgid "Initial per-process concurrency for local LLM dispatching."
msgstr ""

#: agentsociety2.config.Config.LLM_RAY_CONCURRENCY:3 of
msgid "Environment variable: AGENTSOCIETY_LLM_RAY_CONCURRENCY Default: 16"
msgstr "Environment variable: AGENTSOCIETY_LLM_MODEL Default: \"gpt-5.5\""

#: agentsociety2.config.Config.LLM_RAY_CONCURRENCY:6 of
msgid ""
"The initial concurrency each local ``LLMClient`` AIMD semaphore tunes "
"from. Each process adjusts its own concurrency between "
"``LLM_RAY_CONCURRENCY//4`` and ``LLM_RAY_CONCURRENCY*4`` based on "
"observed latency / rate-limit errors."
msgstr ""

