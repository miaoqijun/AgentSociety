#: agentsociety2.backend.routers.modules:12 of
msgid ""
"API端点： - GET /api/v1/modules/agent_classes - 获取所有可用的Agent类 - GET "
"/api/v1/modules/env_module_classes - 获取所有可用的Environment模块类 - GET "
"/api/v1/modules/refresh - 刷新模块列表（重新扫描）"
msgstr ""
"API endpoints: - GET /api/v1/modules/agent_classes - get all available "
"Agent classes - GET /api/v1/modules/env_module_classes - get all "
"available environment module classes - GET /api/v1/modules/refresh - "
"refresh the module list by rescanning"

#: agentsociety2.backend.routers.modules.get_agent_classes:1 of
msgid "获取所有可用的Agent类列表"
msgstr "Get the list of all available Agent classes"

#: agentsociety2.backend.routers.modules.get_agent_classes:3 of
msgid "返回系统中所有已注册的Agent类，包括内置和自定义模块。"
msgstr ""
"Returns all registered Agent classes in the system, including built-in "
"and custom modules."

#: agentsociety2.backend.routers.modules.get_agent_classes:7 of
msgid ""
"Dict[str, Any]: 包含Agent类信息的响应： - success: 是否成功 - agents: "
"Agent类字典，键为类型名，值为： - type: 类型名 - class_name: 类名 - description: 描述 - "
"is_custom: 是否为自定义模块 - count: Agent类总数"
msgstr ""
"Dict[str, Any]: Response containing Agent class information: - success: "
"whether the operation succeeded - agents: dictionary of Agent classes, "
"keyed by type name, with values containing: - type: type name - "
"class_name: class name - description: description - is_custom: whether it"
" is a custom module - count: total number of Agent classes"

#: agentsociety2.backend.routers.modules.get_agent_classes:8 of
msgid "500 - 获取Agent类失败"
msgstr "500 - Failed to get Agent classes"

#: agentsociety2.backend.routers.modules.get_env_module_classes:1 of
msgid "获取所有可用的环境模块类列表"
msgstr "Get the list of all available environment module classes"

#: agentsociety2.backend.routers.modules.get_env_module_classes:3 of
msgid "返回系统中所有已注册的环境模块类，包括内置和自定义模块。"
msgstr ""
"Returns all registered environment module classes in the system, "
"including built-in and custom modules."

#: agentsociety2.backend.routers.modules.get_env_module_classes:7 of
msgid ""
"Dict[str, Any]: 包含环境模块类信息的响应： - success: 是否成功 - modules: "
"环境模块类字典，键为类型名，值为： - type: 类型名 - class_name: 类名 - description: 描述 - "
"is_custom: 是否为自定义模块 - count: 模块类总数"
msgstr ""
"Dict[str, Any]: Response containing environment module class information:"
" - success: whether the operation succeeded - modules: dictionary of "
"environment module classes, keyed by type name, with values containing: -"
" type: type name - class_name: class name - description: description - "
"is_custom: whether it is a custom module - count: total number of module "
"classes"

#: agentsociety2.backend.routers.modules.get_env_module_classes:8 of
msgid "500 - 获取环境模块类失败"
msgstr "500 - Failed to get environment module classes"

#: agentsociety2.backend.routers.modules.get_all_modules:1 of
msgid "获取所有可用的模块类"
msgstr "Get all available module classes"

#: agentsociety2.backend.routers.modules.get_all_modules:3 of
msgid "一次性返回所有Agent类和环境模块类，减少请求次数。"
msgstr ""
"Returns all Agent classes and environment module classes in one call to "
"reduce the number of requests."

#: agentsociety2.backend.routers.modules.get_all_modules:7 of
msgid ""
"Dict[str, Any]: 包含所有模块信息的响应： - success: 是否成功 - agents: Agent类字典 - "
"agent_count: Agent类数量 - env_modules: 环境模块类字典 - env_module_count: 环境模块类数量"
msgstr ""
"Dict[str, Any]: Response containing all module information: - success: "
"whether the operation succeeded - agents: dictionary of Agent classes - "
"agent_count: number of Agent classes - env_modules: dictionary of "
"environment module classes - env_module_count: number of environment "
"module classes"

#: agentsociety2.backend.routers.modules.get_all_modules:8 of
msgid "500 - 获取模块失败"
msgstr "500 - Failed to get modules"

#: ../../api/backend.rst:52
